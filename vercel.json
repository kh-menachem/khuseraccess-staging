{
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm run build",
  "framework": "nextjs",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "PNPM_FLAGS": "--no-frozen-lockfile"
  },
  "installCommand": "pnpm install --no-frozen-lockfile",
  "crons": [
    {
      "path": "/api/cron/daily-error-summary",
      "schedule": "0 8 * * *"
    }
  ]
}
